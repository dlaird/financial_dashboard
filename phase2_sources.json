{
  "_comment": "Phase 2 email parsing config. trusted_forwarders are the Gmail addresses allowed to forward bills. sender_rules match the original sender of the forwarded email.",

  "trusted_forwarders": {
    "k2udal@gmail.com": "D",
    "dalairds@gmail.com": "D",
    "mbdvol@gmail.com": "M"
  },

  "sender_rules": [
    {
      "_comment": "Amazon order confirmations",
      "domain": "amazon.com",
      "payee": "Amazon",
      "account": "evisa"
    },
    {
      "_comment": "Whole Foods (Amazon-owned, separate sender)",
      "domain": "wholefoodsmarket.com",
      "payee": "Whole Foods",
      "account": "evisa"
    },
    {
      "_comment": "City of Austin electric/utility bill — matches on sender name since domain varies",
      "name_contains": "city of austin utilities",
      "payee": "City of Austin Utilities",
      "account": "usaac"
    },
    {
      "_comment": "West Travis County water bill — sent via InvoiceCloud billing service",
      "name_contains": "west travis county",
      "domain": "invoicecloud.net",
      "payee": "West Travis County PUD",
      "account": "usaac"
    },
    {
      "_comment": "Anthropic, Claude Code and API",
      "name_contains": "anthropic",
      "domain": "mail.anthropic.com",
      "payee": "Anthropic",
      "account": "usaae"
    },
   {
      "_comment": "Home Depot",
      "name_contains": "Home Depot",
      "domain": "homedepot.com",
      "payee": "Home Depot",
      "account": "usaae"
    },
   {
      "_comment": "Venmo, various payees, sent via venmo.com domain",
      "name_contains": "Venmo",
      "domain": "venmo.com",
      "payee": "Venmo",
      "account": "usaac",
      "_payee_rules_comment": "Maps extracted payee name (case-insensitive) to category shortcut and display payee name",
      "payee_rules": {
        "flavian martinez": {"category": "lawn",          "payee": "Venmo - Flavian Martinez"},
        "imelda barcenas":  {"category": "housecleaning", "payee": "Venmo - Imelda Barcenas"}
      }
    },
   {
      "_comment": "Google Play Store receipts, sent from googleplay-noreply@google.com",
      "name_contains": "Google Play Store",
      "domain": "googleplay-noreply@google.com",
      "payee": "Google Play Store",
      "account": "usaae"
    },
   {
      "_comment": "PayPal service notifications",
      "name_contains": "PayPal",
      "domain": "service@paypal.com",
      "payee": "PayPal",
      "account": "usaae",
      "_payee_rules_comment": "Maps extracted payee name (case-insensitive) to category shortcut and display payee name",
      "payee_rules": {
        "raul rivera": {"category": "home maintenance", "payee": "PayPal - Raul Rivera"}
      }
    }
  ]
}
